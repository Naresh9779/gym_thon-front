# FitFlow API - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE
# ============================================
# MongoDB connection string
# Get from: https://cloud.mongodb.com
MONGODB_URI=
# JWT SECRETS
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_minimum_32_characters_long

# ============================================
# CORS
# ============================================
# Frontend URL for CORS (your Vercel deployment)
CORS_ORIGIN=https://your-frontend-app.vercel.app

# ============================================
# ADMIN AUTO-CREATION
# ============================================
# Admin account created automatically on startup
ADMIN_EMAIL=admin@fitflow.com
ADMIN_PASSWORD=ChangeThisSecurePassword123!
ADMIN_NAME=Administrator

# ============================================
# AI SERVICES
# ============================================
# OpenRouter API key for AI workout/diet generation
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE

# RapidAPI key for exercise animations/nutrition data
# Get from: https://rapidapi.com
RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY_HERE

# ============================================
# SERVER CONFIG
# ============================================
# Environment mode
NODE_ENV=production

# Server port (Render will provide PORT automatically)
PORT=4000

# ============================================
# CRON SECURITY
# ============================================
# Secret used by Vercel cron jobs to authenticate /api/cron/* endpoints
# Generate with: openssl rand -hex 32
# Must match the value set in Vercel project env vars
CRON_SECRET=your_random_cron_secret_here

# ============================================
# QR CODE / FRONTEND URL
# ============================================
# Full URL of the frontend app — used to generate QR code links for attendance
# Example: https://your-gym-app.vercel.app
APP_URL=https://your-frontend-app.vercel.app
